  "keyFeatures": [
    "Dataset integration across multiple single-cell methods (Harmony, LIGER, Conos, fastMNN)",
    "Trajectory analysis with Monocle3 and RNA velocity",
    "Imputation via ALRA (Adaptively-thresholded Low Rank Approximation)",
    "Spatial transcriptomics support with BANKSY",
    "Dimensionality reduction with GLM-PCA and PaCMAP",
    "Cell type annotation using CIPR",
    "Quality control with miQC",
    "Fast differential expression with Presto",
    "Cell cycle position estimation with tricycle",
    "Seamless Seurat object compatibility"
  ],
